# =============================================================================
# VARIÁVEIS OBRIGATÓRIAS PARA PRODUÇÃO
# Copie este arquivo para .env e preencha todos os valores marcados como [OBRIGATÓRIO]
# NUNCA commite o .env — ele já está no .gitignore
# =============================================================================

# ── Geração de plano IA [OBRIGATÓRIO] ─────────────────────────────────────────
# Obtido no painel do Lovable (workspace > API keys)
LOVABLE_API_KEY=

# ── Mercado Pago [OBRIGATÓRIO] ────────────────────────────────────────────────
# Credenciais de PRODUÇÃO (não sandbox) — painel MP > Credenciais
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# Segredo do webhook — configure em MP > Webhooks e copie o valor gerado
# OBRIGATÓRIO em produção: sem ele todos os webhooks retornam 503
MP_WEBHOOK_SECRET=

# ── Supabase — cliente [OBRIGATÓRIO] ─────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Supabase — servidor SSR [OBRIGATÓRIO em produção] ────────────────────────
# NÃO use prefixo VITE_ — nunca deve ir para o bundle do cliente
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Chave service role — bypassa RLS, use apenas no servidor
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase — ref do projeto (opcional, para scripts de dev) ─────────────────
# VITE_SUPABASE_PROJECT_ID=hscoblnnvlynrlyhhocm

# ── Auth redirect (opcional; padrão = window.location.origin) ─────────────────
# VITE_AUTH_REDIRECT_URL=https://seudominio.com/auth/callback

# ── Scripts de migration (só ambiente local — NÃO vai para o Worker) ──────────
# SUPABASE_ACCESS_TOKEN=sbp_...  # Account → Access Tokens
# SUPABASE_DB_PASSWORD=...       # Project → Database → Settings → Database password
# DATABASE_URL=postgresql://...

# ── SyncPay (opcional — provider alternativo de Pix) ─────────────────────────
# SYNCPAY_CLIENT_ID=
# SYNCPAY_CLIENT_SECRET=
# SYNCPAY_WEBHOOK_SECRET=
