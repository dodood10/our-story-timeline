# Server — geração de plano com IA (obrigatório para /surprise/plan)
LOVABLE_API_KEY=

# Cliente Supabase — sync opcional em Configurações
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# SSR (opcional; o cliente usa VITE_* em build)
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=

# Deploy de migrations (escolha UMA — não vai para o browser)
# SUPABASE_ACCESS_TOKEN=sbp_...   # Account → Access Tokens (NÃO é service_role JWT)
# SUPABASE_DB_PASSWORD=...        # Project → Database → Database password
# DATABASE_URL=postgresql://...

# Servidor SSR apenas (NÃO usar para deploy; NÃO expor no Vite)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
